# Agent Cluster 配置文件
# 在 ~/.bashrc 或 ~/.profile 中 source 此文件，或者直接编辑这里的值

# ============================================================
# 钉钉通知配置
# ============================================================
export DINGTALK_WEBHOOK="https://oapi.dingtalk.com/robot/send?access_token=e182f5a4dc1f109e0655faef95d885aa822a0fb69a9b43c9dbf1ae8fcf760ca3"
# 如果机器人开启了"加签"安全模式，填入签名密钥；否则留空
export DINGTALK_SECRET=""

# ============================================================
# 默认配置
# ============================================================
export AGENT_CLUSTER_DIR="/home/user/projects/agent-cluster"
export AGENT_MAX_RETRIES=3
export AGENT_DEFAULT_AGENT="claude-code"

# ============================================================
# AI Review 配置
# ============================================================
export DASHSCOPE_API_KEY="sk-3de0209251194027883ba9dc373b29fc"
export REVIEW_MODEL="qwen3-coder-plus"
